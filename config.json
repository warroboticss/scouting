  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Team Number",
          "description": "Enter the number of the team you are scouting.",
          "type": "number",
          "required": true,
          "code": "robot",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0
        },
        {
          "title": "First Name & Last Initial",
          "description": "Enter your first name and last initial.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Match Number",
          "description": "Select the match number.",
          "type": "TBA-match-number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "startPos",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "Hub": "Hub",
            "Bump": "Bump",
            "Trench": "Trench"
          }
        },
        {
          "title": "Swerve drivetrain?",
          "description": "Does your robot have a drivetrain that uses swerve (or do they have tank)?",
          "type": "boolean",
          "required": false,
          "code": "swerve",
          "formResetBehavior": "reset",
          "defaultValue": true
        },
        {
          "title": "Turret?",
          "description": "Does your robot have a turret (shooter that can rotate)?",
          "type": "boolean",
          "required": false,
          "code": "turret",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "No Show",
          "description": "Check if the robot did not show up for the match.",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Autonomous",
      "fields": [
        {
          "title": "Sweep count",
          "description": "The number of times the robot swept into fuel.",
          "type": "counter",
          "required": false,
          "code": "autoSweepCount",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 2,
          "step": 1
        },
        {
          "title": "Shooting position",
          "description": "Where did the robot shoot fuel from?",
          "type": "select",
          "required": true,
          "code": "autoShootingPosition",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "trench": "Trench",
            "depot": "Depot",
            "outpost": "Outpost",
            "other": "Other",
            "none": "None"
          }
        },
        {
          "title": "Climbed",
          "description": "Did the robot climb during autonomous?",
          "type": "select",
          "required": false,
          "code": "autoClimbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "Yes": "Climb",
            "F": "Failed Climb"
          }
        },
        {
          "title": "Alliance won auto?",
          "description": "Did your alliance win the autonomous period?",
          "type": "boolean",
          "required": false,
          "code": "allianceWonAuto",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Teleop",
      "fields": [
        {
          "title": "Hopper size",
          "description": "Rate the number of blocks the robot's hopper can hold.",
          "type": "range",
          "required": false,
          "code": "hopperSize",
          "formResetBehavior": "reset",
          "defaultValue": 20,
          "min": 0,
          "max": 60,
          "step": 1
        },
        {
          "title": "Defended during match?",
          "description": "Did the robot play defense during the match?",
          "type": "boolean",
          "required": false,
          "code": "robotDefended",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Climbed",
          "description": "The level the robot climbed during endgame.",
          "type": "select",
          "required": true,
          "code": "climbed",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "No Climb",
            "L1": "Level 1",
            "L2": "Level 2",
            "L3": "Level 3",
            "F": "Failed Climb"
          }
        },
        {
          "title": "DIED?",
          "description": "Did the robot tip or fall over during the match?",
          "type": "boolean",
          "required": false,
          "code": "tipped",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Capabilities",
      "fields": [
        {
          "title": "Movement between zones",
          "description": "How did the robot move between the alliance and neutral zone?",
          "type": "select",
          "required": true,
          "code": "zoneMovement",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "bump": "Bump",
            "trench": "Trench",
            "both": "Both"
          }
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        {
          "title": "Scoring Effectiveness",
          "description": "Rate the robot's scoring effectiveness. 0: No ability to score in hub. 1: Almost never scored during the match. 2: Barely scored; had poor accuracy or fire rate. 3: Scored somewhat well with acceptable accuracy and fire rate. 4: Scored frequently with fast fire rate, cycle times, or accuracy. 5: Scored very frequently with fast cycle times, fire rate, and accuracy",
          "type": "range",
          "required": false,
          "code": "scoringEff",
          "formResetBehavior": "reset",
          "defaultValue": 3,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Defense Effectiveness",
          "description": "Rate the robot's defensive effectiveness. 0: Played no defense. 1: Defense was not impactful or effective at all. 2: Slightly slowed opponents down. 3: Interrupted scoring somewhat. 4: Greatly slowed down opponent scoring. 5: Prevented almost all opponent scoring in a shift",
          "type": "range",
          "required": false,
          "code": "defSkill",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 5,
          "step": 1
        },
        {
          "title": "Yellow/Red Card",
          "type": "select",
          "required": true,
          "code": "yc",
          "formResetBehavior": "reset",
          "defaultValue": "No Card",
          "choices": {
            "No Card": "No Card",
            "Yellow": "Yellow Card",
            "Red": "Red Card"
          }
        },
        {
          "title": "Comments",
          "type": "text",
          "required": false,
          "code": "co",
          "formResetBehavior": "reset",
          "defaultValue": ".",
          "min": 0,
          "max": 100
        }
      ]
    }
  ]
}
